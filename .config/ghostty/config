## font
font-family = "Maple Mono NF CN"
# font-family = "JetBrainsMonoNL Nerd Font Mono"
font-size = 13
# font-thicken = true
# font-feature = "+cv01 +ss02 +ss04 +ss05 +zero"
font-feature = +calt
font-feature = +liga
adjust-cell-height = 3
adjust-cell-width = 1

## theme
theme = Catppuccin Mocha
# theme = light:Catppuccin Latte,dark:Catppuccin Mocha

## window
# background-opacity = 0.8
background-opacity = 0.88
background-blur = 30
# background-blur = 64
# macos-titlebar-style = hidden
# macos-titlebar-style = tabs
# macos-titlebar-proxy-icon = hidden
window-padding-x = 12
window-padding-y = 10
window-padding-balance = true
window-padding-color = extend
window-save-state = always
window-inherit-working-directory = true
window-colorspace = display-p3
window-theme = auto
split-divider-color = #2a2a3a


## cursor
cursor-style = bar
cursor-style-blink = false
cursor-opacity = 1.0

## mouse and clipboard
mouse-hide-while-typing = true
copy-on-select = clipboard
clipboard-trim-trailing-spaces = true
focus-follows-mouse = true

## quick terminal
quick-terminal-position = top
quick-terminal-screen = mouse
quick-terminal-autohide = true
quick-terminal-animation-duration = 0.12

## shell
shell-integration = detect
shell-integration-features = no-cursor
scrollback-limit = 10000000
resize-overlay = after-first
resize-overlay-position = bottom-right
resize-overlay-duration = 500ms

## safe
clipboard-paste-protection = true
clipboard-paste-bracketed-safe = true

## for macOS
# macos-titlebar-style = hidden
macos-icon = custom
macos-custom-icon = /Users/youkipepper/.config/ghostty/rose-pine.icns

## for vibe
# window-width = 160
# window-height = 50
link-url = true